# Caddy reverse-proxy config for the soft-skills platform.
#
# Two modes:
#   - Local dev / IP-based testing: replace `softskills.kiet.edu` with
#     `:80` and Caddy serves plain HTTP without trying Let's Encrypt.
#   - Real deployment: keep the hostname. Caddy auto-provisions TLS via
#     Let's Encrypt as soon as the DNS A record points to this server.
#
# Used by `docker-compose.yml` (the `proxy` service). Don't commit any
# real secrets here.

{
    # Email for Let's Encrypt registration / expiry warnings.
    email admin@kiet.edu
}

# Replace with the real domain before deploying.
softskills.kiet.edu {
    encode zstd gzip

    # WebSocket upgrade pass-through for the battle endpoint.
    @websockets {
        header Connection *Upgrade*
        header Upgrade websocket
    }
    reverse_proxy @websockets app:8080

    # Everything else: HTTP → backend.
    reverse_proxy app:8080 {
        # Keep upstream-aware of the original protocol so FastAPI can
        # build correct redirect URLs when behind TLS.
        header_up X-Forwarded-Proto {scheme}
        header_up X-Forwarded-For {remote}
    }

    # Common security headers. Adjust CSP later when you know all
    # third-party origins (Firebase, Google APIs) at runtime.
    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
        X-Content-Type-Options "nosniff"
        Referrer-Policy "strict-origin-when-cross-origin"
        # Don't leak internal server info.
        -Server
    }

    # Sensible log file (keeps Caddy quiet inside the container otherwise).
    log {
        output stdout
        format console
    }
}
