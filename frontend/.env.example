# Copy to `.env.local` (dev) or `.env.production` (prod build).
# Both files are gitignored. See ../AUTH.md for the Firebase Console
# setup that produces these values.

# When "true", frontend skips Firebase and uses the local demo email
# input. Pair with backend AUTH_BYPASS=true.
VITE_AUTH_BYPASS=true

# Firebase Web SDK config. Required when VITE_AUTH_BYPASS=false.
# All apiKey is a public, domain-restricted key — safe to ship in the bundle.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=
