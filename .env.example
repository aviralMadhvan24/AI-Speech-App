# Copy to .env and edit. `.env` is gitignored.
#
# All values are optional — sensible defaults are in `app/core/config.py`.

# --- Pronunciation provider ---
# One of: hf_phoneme | local | local_acoustic | mock | unavailable
# `hf_phoneme` is the only real acoustic engine that works out of the box.
PRONUNCIATION_PROVIDER=hf_phoneme

# HuggingFace model used by the hf_phoneme provider. Auto-downloads on first
# /analyze call. ~1.26 GB. Override if you need a different phoneme model.
HF_PHONEME_MODEL_NAME=facebook/wav2vec2-lv-60-espeak-cv-ft

# --- Optional: GOPT (acoustic scoring) paths, only used by local_acoustic ---
# GOPT_MODEL_DIR=models/pronunciation/gopt
# GOPT_CHECKPOINT_PATH=models/pronunciation/gopt/pretrained_models/gopt_librispeech/best_audio_model.pth
# GOPT_FEATURE_DIR=temp/gopt_features

# --- Optional: Kaldi GOP wrapper command, only used by local_acoustic ---
# KALDI_GOP_WORK_DIR=temp/kaldi_gop
# KALDI_GOP_COMMAND=

# --- Postgres (currently unused — attempts persist to outputs/attempts.jsonl) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=speech_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# --- Runtime directories (defaults usually fine) ---
UPLOAD_DIR=uploads
OUTPUT_DIR=outputs
TEMP_DIR=temp

# --- Auth (Firebase) ---
# Local-dev shortcut. `true` skips Firebase entirely and treats every
# request as a fake dev@kiet.edu user. Set `false` for any deployment.
AUTH_BYPASS=true

# Provide ONE of the two credential vars below when AUTH_BYPASS=false.
# See AUTH.md for the Firebase Console setup steps.

# Inline JSON (best for cloud env vars):
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"kiet-softskills",...}

# File path (best for dev or Docker secret mount):
# GOOGLE_APPLICATION_CREDENTIALS=/secrets/firebase-admin.json

# --- Auth ---
# Either inline JSON of the Firebase service account credentials, OR set
# GOOGLE_APPLICATION_CREDENTIALS to the path of the JSON file. See AUTH.md.
FIREBASE_SERVICE_ACCOUNT_JSON=
# Skip server-side token verification entirely (dev only). Pairs with
# VITE_AUTH_BYPASS=true on the frontend. Every request becomes dev@kiet.edu.
AUTH_BYPASS=false
